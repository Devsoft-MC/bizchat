NODE_ENV=development
HOST=0.0.0.0
PORT=5001

# Local PostgreSQL database for development
DATABASE_URL=postgresql://localhost:5432/bizchat_local

# Replace before real deployment
JWT_SECRET=change_this_local_secret

# JWT lifetime (examples: 8h, 1d)
JWT_EXPIRES_IN=8h

# Comma-separated web/mobile development origins, or * for local development
CORS_ORIGIN=*
