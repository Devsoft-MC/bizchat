NODE_ENV=development
HOST=0.0.0.0
PORT=5001

# Local PostgreSQL database for development
DATABASE_URL=postgresql://localhost:5432/bizchat_local

# Replace before real deployment
JWT_SECRET=change_this_local_secret

# JWT lifetime (examples: 8h, 1d)
JWT_EXPIRES_IN=8h

# Comma-separated web/mobile development origins, or * for local development
CORS_ORIGIN=*

# Optional until Firebase Cloud Messaging is enabled.
# Use either raw JSON or base64-encoded JSON from a Firebase service account.
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_BASE64=

# LiveKit media server. Keep API credentials on the backend only.
LIVEKIT_URL=wss://your-livekit-host.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Socket.IO path. Production Nginx should proxy this path with WebSocket upgrades.
SOCKET_IO_PATH=/socket.io
