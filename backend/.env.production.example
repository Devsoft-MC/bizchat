NODE_ENV=production
HOST=127.0.0.1
PORT=5001

# PostgreSQL is on the same VPS and must not be exposed publicly.
DATABASE_URL=postgresql://bizchat_app:REPLACE_WITH_URL_ENCODED_PASSWORD@127.0.0.1:5432/bizchatdb

# Generate independently for production, for example: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHARACTER_SECRET
JWT_EXPIRES_IN=8h

# Replace with the final HTTPS web/mobile origin if web preview is deployed.
CORS_ORIGIN=*
