NODE_ENV=production
HOST=127.0.0.1
PORT=5001

# PostgreSQL is on the same VPS and must not be exposed publicly.
DATABASE_URL=postgresql://bizchat_app:REPLACE_WITH_URL_ENCODED_PASSWORD@127.0.0.1:5432/bizchatdb

# Generate independently for production, for example: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHARACTER_SECRET
JWT_EXPIRES_IN=8h

# Replace with the final HTTPS web/mobile origin if web preview is deployed.
CORS_ORIGIN=*

# Firebase Cloud Messaging service account.
# Prefer base64 in VPS/env managers to avoid multiline private-key issues:
# base64 -i firebase-service-account.json
FCM_SERVICE_ACCOUNT_BASE64=

# LiveKit media server and server-side token credentials.
LIVEKIT_URL=wss://rtc.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Nginx should proxy /bizchat/socket.io with WebSocket upgrade headers.
SOCKET_IO_PATH=/bizchat/socket.io
